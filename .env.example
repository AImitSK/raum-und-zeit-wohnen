# E-Mail-Versand der Kontaktanfragen über SendGrid
# API-Key aus dem SendGrid-Dashboard (Settings → API Keys)
SENDGRID_API_KEY=

# Verifizierte Absenderadresse (Single Sender oder Domain-Authentifizierung in SendGrid)
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME="RAUM & ZEIT - Webanfrage"

# Zieladresse, an die die Anfragen zugestellt werden
SENDGRID_FORM_TO_EMAIL=
